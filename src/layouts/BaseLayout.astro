---
import { SITE_STATS } from "../data/siteStats";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Exemplar — The Engineering Stack That Governs Itself",
  description = `${SITE_STATS.properTools} proper tools forming a closed-loop engineering governance stack. From constraint to code to production to tightened contract.`,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL("/og-image.svg", Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- OpenGraph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content="Exemplar" />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={ogImage} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "SoftwareApplication",
      "name": "Exemplar",
      "description": `${SITE_STATS.properTools} proper tools forming a closed-loop engineering governance stack`,
      "url": "https://exemplar.tools",
      "author": {
        "@type": "Person",
        "name": "Jeremy McEntire",
        "url": "https://perardua.dev"
      },
      "license": "https://opensource.org/licenses/MIT",
      "applicationCategory": "DeveloperApplication"
    })} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Instrument+Sans:wght@400;500;600;700&family=DM+Mono:wght@300;400;500&family=JetBrains+Mono:wght@300;400;500;600&display=swap" rel="stylesheet" />

    <!-- WebMCP (A6): expose in-page tools to model-context-aware agents -->
    <script>
      if (navigator.modelContext) {
        navigator.modelContext.provideContext({
          tools: [
            {
              name: "get_site_info",
              description: "Return site metadata",
              inputSchema: { type: "object", properties: {} },
              execute: async () => ({
                site: "exemplar.tools",
                description: "Exemplar — a closed-loop suite of proper tools for governed AI software engineering",
                api_catalog: "/.well-known/api-catalog",
              }),
            },
          ],
        });
      }
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>
