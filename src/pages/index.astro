---
import BaseLayout from "../layouts/BaseLayout.astro";
import "../styles/global.css";
import Pipeline from "../components/Pipeline.tsx";
import TheLoop from "../components/TheLoop.tsx";
import { RESEARCH_FOUNDATION, SITE_STATS } from "../data/siteStats";
import {
  Shield, Brain, Eye, Lock, FileCheck,
  Database, BookOpen, Layers,
  ArrowRight, ExternalLink, Target,
  Cpu, Network, Workflow,
  Fingerprint, FileText, Gauge, Map, Signal,
  Search, Users, Sparkles,
} from "lucide-react";
---

<BaseLayout>
  <!-- ─── Navigation ─── -->
  <nav class="fixed top-0 left-0 right-0 z-50 border-b border-border bg-background/80 backdrop-blur-xl">
    <div class="max-w-7xl mx-auto px-6 h-14 flex items-center justify-between">
      <div class="flex items-center gap-8">
        <a href="#" class="font-mono text-sm font-medium text-foreground tracking-wider uppercase">
          exemplar
        </a>
        <div class="hidden sm:flex items-center gap-6">
          <a href="https://signet.tools" target="_blank" rel="noopener noreferrer" class="font-mono text-xs text-muted hover:text-signet transition-colors">signet</a>
          <a href="https://kindex.tools" target="_blank" rel="noopener noreferrer" class="font-mono text-xs text-muted hover:text-kindex transition-colors">kindex</a>
          <a href="https://herald.tools" target="_blank" rel="noopener noreferrer" class="font-mono text-xs text-muted hover:text-foreground transition-colors">herald</a>
          <a href="https://perardua.dev" target="_blank" rel="noopener noreferrer" class="font-mono text-xs text-muted hover:text-foreground transition-colors">perardua</a>
        </div>
      </div>
      <a href="https://github.com/jmcentire" target="_blank" rel="noopener noreferrer" class="text-muted hover:text-foreground transition-colors">
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
        </svg>
      </a>
    </div>
  </nav>

  <!-- ─── Hero (pain-led rewrite) ─── -->
  <section class="relative min-h-screen flex flex-col items-center justify-center pt-14 overflow-hidden">
    <!-- Grid texture -->
    <div class="absolute inset-0 grid-texture opacity-40"></div>
    <!-- Radial glow -->
    <div class="absolute top-1/3 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[900px] h-[600px] bg-gradient-radial from-white/[0.03] to-transparent rounded-full blur-3xl"></div>

    <div class="relative z-10 max-w-4xl mx-auto px-6 text-center">
      <div class="mb-6">
        <span class="inline-flex items-center gap-2 font-mono text-xs text-muted border border-border rounded-full px-4 py-1.5">
          <span class="w-1.5 h-1.5 rounded-full bg-governance animate-pulse"></span>
          OPEN SOURCE
        </span>
      </div>

      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold tracking-tight leading-[1.12] mb-6">
        Your CI passes. Production breaks.
        <br />
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-foreground via-foreground/80 to-muted">
          The contract that caused it never gets fixed.
        </span>
      </h1>

      <p class="text-lg sm:text-xl text-muted max-w-2xl mx-auto mb-10 font-light">
        Exemplar closes the loop. {SITE_STATS.properTools} proper tools that turn production incidents into tightened contracts. Bugs don't recur — they can't.
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-3 mb-20">
        <a href="#start" class="group flex items-center gap-2 px-6 py-3 bg-foreground text-background font-medium text-sm rounded-md hover:bg-foreground/90 transition-colors">
          Start with one tool
          <ArrowRight className="w-4 h-4 group-hover:translate-x-0.5 transition-transform" />
        </a>
        <a href="#pipeline" class="group flex items-center gap-2 px-6 py-3 border border-border text-muted font-medium text-sm rounded-md hover:border-border-bright hover:text-foreground transition-colors">
          Explore the Stack
          <ArrowRight className="w-4 h-4 group-hover:translate-x-0.5 transition-transform" />
        </a>
        <a href="https://github.com/jmcentire" target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 px-6 py-3 border border-border text-muted font-medium text-sm rounded-md hover:border-border-bright hover:text-foreground transition-colors">
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
          </svg>
          View on GitHub
        </a>
      </div>

      <div class="flex items-center justify-center gap-8 sm:gap-12">
        <div class="text-center">
          <p class="font-mono text-2xl sm:text-3xl font-medium text-foreground">{SITE_STATS.activeResearchPapers}</p>
          <p class="font-mono text-xs text-muted uppercase tracking-wider mt-1">papers</p>
        </div>
        <div class="text-center">
          <p class="font-mono text-2xl sm:text-3xl font-medium text-foreground">{SITE_STATS.tests}</p>
          <p class="font-mono text-xs text-muted uppercase tracking-wider mt-1">tests</p>
        </div>
        <div class="text-center">
          <p class="font-mono text-2xl sm:text-3xl font-medium text-foreground">{SITE_STATS.properTools}</p>
          <p class="font-mono text-xs text-muted uppercase tracking-wider mt-1">proper tools</p>
        </div>
        <div class="text-center">
          <p class="font-mono text-2xl sm:text-3xl font-medium text-foreground">{SITE_STATS.languages}</p>
          <p class="font-mono text-xs text-muted uppercase tracking-wider mt-1">languages</p>
        </div>
      </div>
    </div>

    <!-- Bottom fade -->
    <div class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-background to-transparent"></div>
  </section>

  <!-- ─── Pipeline (React Island) ─── -->
  <Pipeline client:visible />

  <!-- ─── The Loop (React Island) ─── -->
  <TheLoop client:visible />

  <!-- ─── Project Cards (Static) ─── -->
  <section id="projects" class="py-32 relative">
    <div class="absolute inset-0 grid-texture opacity-15"></div>
    <div class="relative z-10 max-w-7xl mx-auto px-6">
      <div class="text-center mb-4">
        <span class="font-mono text-xs text-muted uppercase tracking-widest">{SITE_STATS.properTools} Proper Tools</span>
      </div>
      <div class="text-center mb-16">
        <h2 class="text-3xl sm:text-4xl font-bold tracking-tight">
          The complete stack
        </h2>
      </div>

      <div class="space-y-16">
        <!-- Trust & Privacy -->
        <div>
          <div class="mb-6 flex items-center gap-3">
            <span class="font-mono text-xs text-signet uppercase tracking-widest">Trust & Privacy</span>
            <div class="h-px flex-1 bg-signet/10"></div>
            <a href="https://signet.tools" target="_blank" rel="noopener noreferrer" class="font-mono text-[11px] text-signet hover:underline flex items-center gap-1">
              signet.tools
              <ExternalLink className="w-3 h-3" />
            </a>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
            <a href="https://github.com/jmcentire/signet" target="_blank" rel="noopener noreferrer" class="block p-5 rounded-lg border bg-card hover:bg-card-hover transition-all duration-200 group border-signet/20 hover:shadow-lg hover:shadow-black/20 hover:-translate-y-0.5">
              <div class="flex items-start justify-between mb-3">
                <div class="flex items-center gap-2.5">
                  <Lock className="w-4 h-4 text-signet opacity-60" />
                  <h3 class="text-sm font-semibold">Signet</h3>
                </div>
                <ExternalLink className="w-3.5 h-3.5 text-dim opacity-0 group-hover:opacity-100 transition-opacity" />
              </div>
              <p class="text-xs text-muted leading-relaxed mb-3">Personal sovereign agent stack. Cryptographic vault, ZK proofs, Ed25519 identity.</p>
              <div class="flex items-center gap-2">
                <span class="font-mono text-[10px] px-2 py-0.5 rounded text-orange-400 bg-orange-400/10">Rust</span>
                <span class="font-mono text-[10px] text-dim">473 tests</span>
              </div>
            </a>
            <a href="https://github.com/jmcentire/signet-eval" target="_blank" rel="noopener noreferrer" class="block p-5 rounded-lg border bg-card hover:bg-card-hover transition-all duration-200 group border-signet/20 hover:shadow-lg hover:shadow-black/20 hover:-translate-y-0.5">
              <div class="flex items-start justify-between mb-3">
                <div class="flex items-center gap-2.5">
                  <Shield className="w-4 h-4 text-signet opacity-60" />
                  <h3 class="text-sm font-semibold">signet-eval</h3>
                </div>
                <ExternalLink className="w-3.5 h-3.5 text-dim opacity-0 group-hover:opacity-100 transition-opacity" />
              </div>
              <p class="text-xs text-muted leading-relaxed mb-3">Deterministic policy enforcement for AI agent tool calls.</p>
              <div class="flex items-center gap-2">
                <span class="font-mono text-[10px] px-2 py-0.5 rounded text-orange-400 bg-orange-400/10">Rust</span>
                <span class="font-mono text-[10px] text-dim">88 tests</span>
              </div>
            </a>
            <a href="https://github.com/jmcentire/agent-safe" target="_blank" rel="noopener noreferrer" class="block p-5 rounded-lg border bg-card hover:bg-card-hover transition-all duration-200 group border-signet/20 hover:shadow-lg hover:shadow-black/20 hover:-translate-y-0.5">
              <div class="flex items-start justify-between mb-3">
                <div class="flex items-center gap-2.5">
                  <Fingerprint className="w-4 h-4 text-signet opacity-60" />
                  <h3 class="text-sm font-semibold">Agent-Safe</h3>
                </div>
                <ExternalLink className="w-3.5 h-3.5 text-dim opacity-0 group-hover:opacity-100 transition-opacity" />
              </div>
              <p class="text-xs text-muted leading-relaxed mb-3">SPL authorization language. Six SDK implementations, ~2us evaluation.</p>
              <div class="flex items-center gap-2">
                <span class="font-mono text-[10px] px-2 py-0.5 rounded text-purple-400 bg-purple-400/10">Multi</span>
              </div>
            </a>
          </div>
        </div>

        <!-- Intelligence -->
        <div>
          <div class="mb-6 flex items-center gap-3">
            <span class="font-mono text-xs text-kindex uppercase tracking-widest">Intelligence</span>
            <div class="h-px flex-1 bg-kindex/10"></div>
            <a href="https://kindex.tools" target="_blank" rel="noopener noreferrer" class="font-mono text-[11px] text-kindex hover:underline flex items-center gap-1">
              kindex.tools
              <ExternalLink className="w-3 h-3" />
            </a>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
            <a href="https://github.com/jmcentire/kindex" target="_blank" rel="noopener noreferrer" class="block p-5 rounded-lg border bg-card hover:bg-card-hover transition-all duration-200 group border-kindex/20 hover:shadow-lg hover:shadow-black/20 hover:-translate-y-0.5">
              <div class="flex items-start justify-between mb-3">
                <div class="flex items-center gap-2.5">
                  <Brain className="w-4 h-4 text-kindex opacity-60" />
                  <h3 class="text-sm font-semibold">Kindex</h3>
                </div>
                <ExternalLink className="w-3.5 h-3.5 text-dim opacity-0 group-hover:opacity-100 transition-opacity" />
              </div>
              <p class="text-xs text-muted leading-relaxed mb-3">Persistent knowledge graph for AI-assisted workflows. 37 MCP tools, hybrid FTS5+graph search.</p>
              <div class="flex items-center gap-2">
                <span class="font-mono text-[10px] px-2 py-0.5 rounded text-blue-400 bg-blue-400/10">Python</span>
                <span class="font-mono text-[10px] text-dim">930 tests</span>
              </div>
            </a>
            <a href="https://github.com/jmcentire/apprentice" target="_blank" rel="noopener noreferrer" class="block p-5 rounded-lg border bg-card hover:bg-card-hover transition-all duration-200 group border-kindex/20 hover:shadow-lg hover:shadow-black/20 hover:-translate-y-0.5">
              <div class="flex items-start justify-between mb-3">
                <div class="flex items-center gap-2.5">
                  <Cpu className="w-4 h-4 text-kindex opacity-60" />
                  <h3 class="text-sm font-semibold">Apprentice</h3>
                </div>
                <ExternalLink className="w-3.5 h-3.5 text-dim opacity-0 group-hover:opacity-100 transition-opacity" />
              </div>
              <p class="text-xs text-muted leading-relaxed mb-3">Adaptive model distillation. Routes between frontier API and local fine-tuned model.</p>
              <div class="flex items-center gap-2">
                <span class="font-mono text-[10px] px-2 py-0.5 rounded text-blue-400 bg-blue-400/10">Python</span>
                <span class="font-mono text-[10px] text-dim">2,628 tests</span>
              </div>
            </a>
            <a href="https://github.com/jmcentire/chronicler" target="_blank" rel="noopener noreferrer" class="block p-5 rounded-lg border bg-card hover:bg-card-hover transition-all duration-200 group border-kindex/20 hover:shadow-lg hover:shadow-black/20 hover:-translate-y-0.5">
              <div class="flex items-start justify-between mb-3">
                <div class="flex items-center gap-2.5">
                  <BookOpen className="w-4 h-4 text-kindex opacity-60" />
                  <h3 class="text-sm font-semibold">Chronicler</h3>
                </div>
                <ExternalLink className="w-3.5 h-3.5 text-dim opacity-0 group-hover:opacity-100 transition-opacity" />
              </div>
              <p class="text-xs text-muted leading-relaxed mb-3">Event collection and story assembly. Weaves operational events into narratives.</p>
              <div class="flex items-center gap-2">
                <span class="font-mono text-[10px] px-2 py-0.5 rounded text-blue-400 bg-blue-400/10">Python</span>
              </div>
            </a>
            <a href="https://github.com/jmcentire/transmogrifier" target="_blank" rel="noopener noreferrer" class="block p-5 rounded-lg border bg-card hover:bg-card-hover transition-all duration-200 group border-kindex/20 hover:shadow-lg hover:shadow-black/20 hover:-translate-y-0.5">
              <div class="flex items-start justify-between mb-3">
                <div class="flex items-center gap-2.5">
                  <Sparkles className="w-4 h-4 text-kindex opacity-60" />
                  <h3 class="text-sm font-semibold">Transmogrifier</h3>
                </div>
                <ExternalLink className="w-3.5 h-3.5 text-dim opacity-0 group-hover:opacity-100 transition-opacity" />
              </div>
              <p class="text-xs text-muted leading-relaxed mb-3">Register-aware prompt translation. Detects linguistic register and normalizes for optimal LLM output. 18.8pp accuracy improvement on Claude, 56pp on Gemini. Middleware for Constrain, Pact, Kindex, Webprobe, and Advocate.</p>
              <div class="flex items-center gap-2">
                <span class="font-mono text-[10px] px-2 py-0.5 rounded text-blue-400 bg-blue-400/10">Python</span>
              </div>
            </a>
          </div>
        </div>

        <!-- Governance -->
        <div>
          <div class="mb-6 flex items-center gap-3">
            <span class="font-mono text-xs text-governance uppercase tracking-widest">Governance</span>
            <div class="h-px flex-1 bg-governance/10"></div>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
            <a href="https://github.com/jmcentire/pact" target="_blank" rel="noopener noreferrer" class="block p-5 rounded-lg border bg-card hover:bg-card-hover transition-all duration-200 group border-governance/20 hover:shadow-lg hover:shadow-black/20 hover:-translate-y-0.5">
              <div class="flex items-start justify-between mb-3">
                <div class="flex items-center gap-2.5">
                  <FileText className="w-4 h-4 text-governance opacity-60" />
                  <h3 class="text-sm font-semibold">Pact</h3>
                </div>
                <ExternalLink className="w-3.5 h-3.5 text-dim opacity-0 group-hover:opacity-100 transition-opacity" />
              </div>
              <p class="text-xs text-muted leading-relaxed mb-3">Contract-first multi-agent software engineering. 10-phase pipeline.</p>
              <div class="flex items-center gap-2">
                <span class="font-mono text-[10px] px-2 py-0.5 rounded text-blue-400 bg-blue-400/10">Python</span>
                <span class="font-mono text-[10px] text-dim">1,814 tests</span>
              </div>
            </a>
            <a href="https://github.com/jmcentire/constrain" target="_blank" rel="noopener noreferrer" class="block p-5 rounded-lg border bg-card hover:bg-card-hover transition-all duration-200 group border-governance/20 hover:shadow-lg hover:shadow-black/20 hover:-translate-y-0.5">
              <div class="flex items-start justify-between mb-3">
                <div class="flex items-center gap-2.5">
                  <Layers className="w-4 h-4 text-governance opacity-60" />
                  <h3 class="text-sm font-semibold">Constrain</h3>
                </div>
                <ExternalLink className="w-3.5 h-3.5 text-dim opacity-0 group-hover:opacity-100 transition-opacity" />
              </div>
              <p class="text-xs text-muted leading-relaxed mb-3">Interactive constraint elicitation. LLM interviews extract project boundaries.</p>
              <div class="flex items-center gap-2">
                <span class="font-mono text-[10px] px-2 py-0.5 rounded text-blue-400 bg-blue-400/10">Python</span>
                <span class="font-mono text-[10px] text-dim">259 tests</span>
              </div>
            </a>
            <a href="https://github.com/jmcentire/baton" target="_blank" rel="noopener noreferrer" class="block p-5 rounded-lg border bg-card hover:bg-card-hover transition-all duration-200 group border-governance/20 hover:shadow-lg hover:shadow-black/20 hover:-translate-y-0.5">
              <div class="flex items-start justify-between mb-3">
                <div class="flex items-center gap-2.5">
                  <Network className="w-4 h-4 text-governance opacity-60" />
                  <h3 class="text-sm font-semibold">Baton</h3>
                </div>
                <ExternalLink className="w-3.5 h-3.5 text-dim opacity-0 group-hover:opacity-100 transition-opacity" />
              </div>
              <p class="text-xs text-muted leading-relaxed mb-3">Cloud-agnostic circuit orchestration. Pre-wired topologies, self-healing.</p>
              <div class="flex items-center gap-2">
                <span class="font-mono text-[10px] px-2 py-0.5 rounded text-blue-400 bg-blue-400/10">Python</span>
                <span class="font-mono text-[10px] text-dim">804 tests</span>
              </div>
            </a>
            <a href="https://github.com/jmcentire/arbiter" target="_blank" rel="noopener noreferrer" class="block p-5 rounded-lg border bg-card hover:bg-card-hover transition-all duration-200 group border-governance/20 hover:shadow-lg hover:shadow-black/20 hover:-translate-y-0.5">
              <div class="flex items-start justify-between mb-3">
                <div class="flex items-center gap-2.5">
                  <Gauge className="w-4 h-4 text-governance opacity-60" />
                  <h3 class="text-sm font-semibold">Arbiter</h3>
                </div>
                <ExternalLink className="w-3.5 h-3.5 text-dim opacity-0 group-hover:opacity-100 transition-opacity" />
              </div>
              <p class="text-xs text-muted leading-relaxed mb-3">Trust enforcement. Append-only ledger, SHA-256 integrity, canary taint tracking.</p>
              <div class="flex items-center gap-2">
                <span class="font-mono text-[10px] px-2 py-0.5 rounded text-blue-400 bg-blue-400/10">Python</span>
              </div>
            </a>
            <a href="https://github.com/jmcentire/sentinel" target="_blank" rel="noopener noreferrer" class="block p-5 rounded-lg border bg-card hover:bg-card-hover transition-all duration-200 group border-governance/20 hover:shadow-lg hover:shadow-black/20 hover:-translate-y-0.5">
              <div class="flex items-start justify-between mb-3">
                <div class="flex items-center gap-2.5">
                  <Target className="w-4 h-4 text-governance opacity-60" />
                  <h3 class="text-sm font-semibold">Sentinel</h3>
                </div>
                <ExternalLink className="w-3.5 h-3.5 text-dim opacity-0 group-hover:opacity-100 transition-opacity" />
              </div>
              <p class="text-xs text-muted leading-relaxed mb-3">Production attribution via PACT keys. Spawns LLM fixer agents.</p>
              <div class="flex items-center gap-2">
                <span class="font-mono text-[10px] px-2 py-0.5 rounded text-blue-400 bg-blue-400/10">Python</span>
                <span class="font-mono text-[10px] text-dim">177 tests</span>
              </div>
            </a>
            <a href="https://github.com/jmcentire/ledger" target="_blank" rel="noopener noreferrer" class="block p-5 rounded-lg border bg-card hover:bg-card-hover transition-all duration-200 group border-governance/20 hover:shadow-lg hover:shadow-black/20 hover:-translate-y-0.5">
              <div class="flex items-start justify-between mb-3">
                <div class="flex items-center gap-2.5">
                  <Database className="w-4 h-4 text-governance opacity-60" />
                  <h3 class="text-sm font-semibold">Ledger</h3>
                </div>
                <ExternalLink className="w-3.5 h-3.5 text-dim opacity-0 group-hover:opacity-100 transition-opacity" />
              </div>
              <p class="text-xs text-muted leading-relaxed mb-3">Schema registry and data obligation manager. 12 backend types.</p>
              <div class="flex items-center gap-2">
                <span class="font-mono text-[10px] px-2 py-0.5 rounded text-blue-400 bg-blue-400/10">Python</span>
                <span class="font-mono text-[10px] text-dim">276 tests</span>
              </div>
            </a>
